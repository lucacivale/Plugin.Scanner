<Page
    x:Class="Plugin.Scanner.Uno.Tests.Presentation.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{ThemeResource BackgroundBrush}"
    NavigationCacheMode="Required">
    <ScrollViewer IsTabStop="True">
        <Grid utu:SafeArea.Insets="VisibleBounds">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
            </Grid.RowDefinitions>
            <utu:NavigationBar Content="Plugin.Scanner.Uno" />

            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="16">

                <Button Command="{Binding ScanBarcode}" Content="Scan barcode" />
                <TextBlock Text="{Binding Barcode, Mode=TwoWay}" />

                <Button Command="{Binding ScanText}" Content="Scan text" />
                <TextBlock Text="{Binding Text, Mode=TwoWay}" />

                <Button Command="{Binding ScanDocuments}" Content="Scan documents" />
                <TextBlock Text="{Binding ScannedDocuments, Mode=TwoWay}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
